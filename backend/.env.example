# Lawyer Office AI Engine — environment template.
# Copy to .env and fill in per-firm values (the provision script writes these in production).
# Secrets like the LLM API key and WAHA credentials live in the firm_settings table, NOT here.

# Postgres connection for the app role (asyncpg DSN)
DATABASE_URL=postgresql://app_user:CHANGE_ME@db:5432/postgres

# GoTrue JWT verification (HS256, audience "authenticated") — fresh per firm, never a default
GOTRUE_JWT_SECRET=CHANGE_ME

# Self-hosted Supabase (per-firm stack)
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_KEY=CHANGE_ME

# Google Document AI (live OCR intake)
DOCAI_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-credentials.json

# OCR confidence gate (below this => documents.status = low_confidence)
OCR_CONFIDENCE_THRESHOLD=0.80

# Read-only shared Egyptian-law corpus (empty => shared corpus disabled)
SHARED_CORPUS_DATABASE_URL=
