# ============================================================================
# Per-firm .env template — rendered by infra/provision/provision_firm.sh
# ============================================================================
# Every ${VAR} below is substituted by envsubst with FRESH per-firm values
# at provision time [C-XI]. Never commit a rendered .env; the rendered file
# lives at /opt/firms/<slug>/.env with chmod 600.
#
# Secrets that belong to the FIRM (WAHA key, LLM API key, embedding config)
# are NOT here — they live in the firm_settings table and are entered via
# the dashboard (IMPLEMENTATION_CONVENTIONS.md, Settings).

# ---- Identity / routing ----------------------------------------------------
# Compose project name = firm slug (namespaces containers/volumes) [C-I]
COMPOSE_PROJECT_NAME=${FIRM_SLUG}
FIRM_SLUG=${FIRM_SLUG}
BASE_DOMAIN=${BASE_DOMAIN}
# Full firm domain used in Traefik Host() rules:
#   https://FIRM_DOMAIN            -> frontend
#   https://api.FIRM_DOMAIN        -> backend
#   https://supabase.FIRM_DOMAIN   -> kong (GoTrue/PostgREST/Storage)
FIRM_DOMAIN=${FIRM_SLUG}.${BASE_DOMAIN}
SITE_URL=https://${FIRM_SLUG}.${BASE_DOMAIN}
# Public URL of GoTrue as seen by clients (through Kong + Traefik).
API_EXTERNAL_URL=https://supabase.${FIRM_SLUG}.${BASE_DOMAIN}
# Comma-separated extra allowed auth redirect URLs (usually empty).
ADDITIONAL_REDIRECT_URLS=

# ---- Build contexts (absolute repo paths; written by provision script) -------
# The compose file is copied into the firm dir, so a relative '../backend' would
# resolve outside the repo. These pin the app image build contexts so
# `docker compose build` works regardless of where the firm dir lives.
BACKEND_CONTEXT=${BACKEND_CONTEXT}
FRONTEND_CONTEXT=${FRONTEND_CONTEXT}

# ---- Postgres ----------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Backend application role (created by migrations; password set by provision).
APP_USER_PASSWORD=${APP_USER_PASSWORD}
DATABASE_URL=postgresql://app_user:${APP_USER_PASSWORD}@db:5432/postgres
# BYPASSRLS service role for background workers / system contexts (migration 0010).
# Shares APP_USER_PASSWORD; app_service = app_user grants + BYPASSRLS (not superuser).
SERVICE_DATABASE_URL=postgresql://app_service:${APP_USER_PASSWORD}@db:5432/postgres

# ---- Supabase auth (GoTrue) / API keys --------------------------------------
# HS256 secret shared by GoTrue, Kong and the backend JWT verification.
JWT_SECRET=${JWT_SECRET}
GOTRUE_JWT_SECRET=${JWT_SECRET}
JWT_EXPIRY=3600

# Derived HS256 JWTs (role=anon / role=service_role, iss=supabase, 10y exp),
# signed with JWT_SECRET by the provision script.
ANON_KEY=${ANON_KEY}
SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# ---- Backend (FastAPI) -------------------------------------------------------
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_KEY=${SERVICE_ROLE_KEY}
STORAGE_BUCKET=documents

# Allowed browser origins for the API (the firm dashboard origin).
CORS_ORIGINS=https://${FIRM_SLUG}.${BASE_DOMAIN}

# Google Document AI (live OCR intake) — fill per deployment.
DOCAI_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=
# Path INSIDE the container — docker-compose mounts ./secrets/google-credentials.json here.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-credentials.json
OCR_CONFIDENCE_THRESHOLD=0.80

# Shared Egyptian-law corpus (read-only, PUBLIC LAW ONLY). Empty = disabled.
SHARED_CORPUS_DATABASE_URL=

# ---- Frontend (Next.js) ------------------------------------------------------
# Supabase is reached through the Kong gateway (supabase.<firm-domain>), NOT
# the FastAPI backend.
NEXT_PUBLIC_SUPABASE_URL=https://supabase.${FIRM_SLUG}.${BASE_DOMAIN}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
NEXT_PUBLIC_API_URL=https://api.${FIRM_SLUG}.${BASE_DOMAIN}

# ---- Supabase Studio (NOT publicly exposed — SSH tunnel only [C-XI]) --------
# docker-compose binds Studio to 127.0.0.1:54323 on the host.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=${DASHBOARD_PASSWORD}
