# =============================================================================
# Per-firm environment template — infra/env.template
# =============================================================================
# The provision script (infra/provision/provision_firm.sh) renders an env
# template to /opt/firms/<slug>/.env, substituting every placeholder with
# FRESH, firm-specific values. (It prefers infra/provision/env.template and
# falls back to this file — both carry the same envsubst placeholders.)
#
# !!! ███ NEVER USE DEFAULT OR PLACEHOLDER SECRETS IN ANY ENVIRONMENT ███ !!!
# !!! Every secret below (POSTGRES_PASSWORD, JWT_SECRET, ANON_KEY,        !!!
# !!! SERVICE_ROLE_KEY, ...) MUST be freshly generated per firm by the    !!!
# !!! provision script. A default JWT secret allows TOKEN FORGERY against !!!
# !!! confidential legal data. [Constitution C-XI]                        !!!
#
# Template syntax: ${VAR} references in THIS file are resolved by the
# provision script (envsubst) when rendering infra/.env — the rendered .env
# contains only concrete literal values. The rendered file is consumed twice:
#   1. docker-compose variable interpolation (${VAR} in docker-compose.yml)
#   2. env_file for backend/worker containers (pydantic-settings reads the
#      lowercase-matching fields — see backend/app/core/config.py)
# =============================================================================

# -----------------------------------------------------------------------------
# Firm identity & routing
# -----------------------------------------------------------------------------
# Compose project name = firm slug. Namespaces containers/volumes/networks so
# multiple firm stacks coexist on one host with zero sharing. [C-I]
COMPOSE_PROJECT_NAME=${FIRM_SLUG}

# Short unique slug for this firm (lowercase, [a-z0-9-]). Used in Traefik
# router/service names and image tags. Must match COMPOSE_PROJECT_NAME.
FIRM_SLUG=${FIRM_SLUG}

# Base domain served by this host's Traefik (wildcard DNS *.DOMAIN -> host IP).
DOMAIN=${BASE_DOMAIN}

# This firm's full domain. Frontend at https://FIRM_DOMAIN, backend at
# https://api.FIRM_DOMAIN, Supabase gateway at https://supabase.FIRM_DOMAIN.
# Requires wildcard DNS for *.FIRM_DOMAIN as well (covered by *.DOMAIN only if
# you use flat naming; the default pattern <slug>.<DOMAIN> needs
# *.<slug>.<DOMAIN> resolved — a wildcard *.DOMAIN A record does NOT cover
# second-level subdomains, so add *.<slug>.<DOMAIN> or use a per-firm wildcard.
# Traefik requests the cert for FIRM_DOMAIN + *.FIRM_DOMAIN via DNS-01.)
FIRM_DOMAIN=${FIRM_SLUG}.${BASE_DOMAIN}

# -----------------------------------------------------------------------------
# Postgres  (SECRET — generate fresh: openssl rand -hex 32)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# -----------------------------------------------------------------------------
# Supabase JWT + API keys
# JWT_SECRET: >= 40 chars, fresh per firm (openssl rand -hex 32).
# ANON_KEY / SERVICE_ROLE_KEY: JWTs signed with JWT_SECRET (role=anon /
# role=service_role) — the provision script mints them with the standard
# supabase self-host key generator. SERVICE_ROLE_KEY bypasses RLS: server-side
# only, never shipped to the browser, never logged. [C-III][C-XI]
# -----------------------------------------------------------------------------
JWT_SECRET=${JWT_SECRET}
ANON_KEY=${ANON_KEY}
SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# GoTrue verifies/signs with the same secret (backend verifies tokens with it).
GOTRUE_JWT_SECRET=${JWT_SECRET}

# Public URL of the GoTrue API as seen by clients (through Kong + Traefik).
API_EXTERNAL_URL=https://supabase.${FIRM_SLUG}.${BASE_DOMAIN}
# Where auth redirects land (the dashboard).
SITE_URL=https://${FIRM_SLUG}.${BASE_DOMAIN}
# Comma-separated extra allowed redirect URLs (usually empty).
ADDITIONAL_REDIRECT_URLS=

# -----------------------------------------------------------------------------
# Backend (FastAPI + workers) — read via pydantic-settings
# -----------------------------------------------------------------------------
# App connects as role `app_user` (created by migrations; password set by the
# provision script — fresh per firm).
DATABASE_URL=postgresql://app_user:${APP_USER_PASSWORD}@db:5432/postgres

# Supabase reached server-side through Kong on the internal network.
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_KEY=${SERVICE_ROLE_KEY}

# Allowed browser origins for the API (the firm's dashboard origin).
CORS_ORIGINS=https://${FIRM_SLUG}.${BASE_DOMAIN}

# Google Document AI (live OCR intake). Credentials JSON is mounted at
# /run/secrets/google-credentials.json (see docker-compose.yml) — never inline
# the key material in this file.
# Operator fills these per deployment (empty = OCR intake not yet enabled).
DOCAI_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=

# OCR confidence gate threshold — documents below it are marked low_confidence
# and every derived output carries a heightened warning. [C-VII]
OCR_CONFIDENCE_THRESHOLD=0.80

# Read-only shared Egyptian-law corpus (PUBLIC LAW ONLY — no firm/client data
# may ever enter it). Leave empty to disable shared-corpus retrieval.
# Use a READ-ONLY database role.
SHARED_CORPUS_DATABASE_URL=

# NOTE: LLM API key, WAHA url/key and embedding config are NOT env vars — they
# live in the firm_settings table (masked in API responses, redacted in audit
# logs). [C-III][C-XI]

# -----------------------------------------------------------------------------
# Frontend (Next.js) — NEXT_PUBLIC_* are PUBLIC (baked into the browser
# bundle). Never put service keys here; the anon key is the only key allowed.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://supabase.${FIRM_SLUG}.${BASE_DOMAIN}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
NEXT_PUBLIC_API_URL=https://api.${FIRM_SLUG}.${BASE_DOMAIN}
