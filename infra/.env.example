# Copy to infra/.env and fill every value before first deploy.
# NEVER commit infra/.env to git.

# ── Supabase Cloud ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app_user:<password>@db.<ref>.supabase.co:5432/postgres
SERVICE_DATABASE_URL=postgresql://app_service:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role key>

# ── GoTrue JWT ─────────────────────────────────────────────────────────────────
GOTRUE_JWT_SECRET=<Dashboard → Settings → API → JWT secret>

# ── Frontend public vars (baked into Next.js bundle at build time) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
NEXT_PUBLIC_API_URL=https://api.<your-domain>

# ── Google Document AI ─────────────────────────────────────────────────────────
DOCAI_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=

# ── Paymob billing ────────────────────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://<your-domain>

# ── WAHA Plus (WhatsApp) ──────────────────────────────────────────────────────
WAHA_URL=http://waha:3000
WAHA_API_KEY=
